[Unit]
Description=Comet Panel Dashboard
After=network.target

[Service]
Type=simple
Environment=PATH=/home/shanl/.nvm/versions/node/v24.18.0/bin:/home/shanl/.cargo/bin:/usr/local/bin:/usr/bin:/bin
WorkingDirectory=/home/shanl/workspace/comet-panel
ExecStart=/home/shanl/workspace/comet-panel/comet-panel --port 8989 --bind 0.0.0.0 --dir ../miao/openspec
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
